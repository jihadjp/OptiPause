<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_main_gradient" />

    <View
        android:layout_width="350dp"
        android:layout_height="350dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-80dp"
        android:layout_marginEnd="-100dp"
        android:background="@drawable/bg_glow_blob_primary"
        android:alpha="0.25" />

    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="-100dp"
        android:layout_marginBottom="-50dp"
        android:background="@drawable/bg_glow_blob_secondary"
        android:alpha="0.15" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="32dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardBackgroundColor="@color/surface_card"
            app:strokeColor="@color/stroke_glass"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="48dp"
                android:paddingHorizontal="24dp">

                <FrameLayout
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_marginBottom="24dp">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_icon_circle"
                        android:alpha="0.15"/>

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_timer_notification"
                        app:tint="?attr/colorPrimary" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Time's Up!"
                    android:textAppearance="@style/TextAppearance.OptiPause.ToolbarTitle"
                    android:textSize="32sp"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Take a break and rest your eyes."
                    android:textSize="16sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textAlignment="center"
                    android:layout_marginBottom="40dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStopAndBreak"
                    style="@style/Widget.OptiPause.Button.Gradient"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="Stop Alarm &amp; Break"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    app:icon="@drawable/ic_stop"
                    app:iconGravity="textStart"
                    app:iconPadding="12dp"
                    app:iconSize="22dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</FrameLayout>